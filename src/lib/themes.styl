// =============================================================================
//  LCARS · Themes
// -----------------------------------------------------------------------------
//  A theme is a preset that remaps the --lcars-* roles. Add a theme class on the
//  SAME element as `.lcars` (so it overrides the defaults set in tokens.styl):
//
//      <div class="lcars lcars-theme-klingon"> … </div>
//
//  Because every component reads var(--lcars-*), the whole UI re-skins instantly.
//  Two families:
//    · Federation eras  — tng · picard · ds9 · voyager
//    · Factions         — romulan · ferengi · klingon · cardassian
//
//  Imported after tokens.styl so equal-specificity (single class) wins by order.
//  Each theme also remaps the few named stops components touch directly
//  (pale-canary = highlight/focus, hopbush = active-press, butterscotch = cycle).
// =============================================================================

// ---- Federation: TNG (the classic look — explicit so you can switch back) ----
.lcars-theme-tng
  --lcars-bg            #000000
  --lcars-panel         #0a0a0a
  --lcars-text          #ffffff
  --lcars-primary       #ffcc66
  --lcars-secondary     #99ccff
  --lcars-tertiary      #cc99cc
  --lcars-accent        #ff9900
  --lcars-muted         #9999cc
  --lcars-danger        #ff3030
  --lcars-warning       #ff9933
  --lcars-success       #66cc66
  --lcars-pale-canary   #ffff99
  --lcars-hopbush       #cc6699
  --lcars-butterscotch  #ff9966

