// =============================================================================
//  Component · Tabs
// -----------------------------------------------------------------------------
//  A horizontal rail of pill tabs. The active tab lights up in the primary
//  colour; the row reads as one continuous bar with rounded ends.
//
//    <div class="lcars-tabs">
//      <button class="lcars-tabs__tab is-active">Tactical</button>
//      <button class="lcars-tabs__tab">Science</button>
//      <button class="lcars-tabs__tab">Comms</button>
//    </div>
// =============================================================================

.lcars-tabs
  display inline-flex
  flex-direction row
  gap var(--lcars-gap, $lcars-gap)
  align-items stretch

  &__tab
    display flex
    align-items center
    justify-content center
    box-sizing border-box
    min-width 6rem
    height var(--lcars-unit-h, $lcars-unit-h)
    padding 0 1rem
    border none
    border-radius 0
    background var(--lcars-muted, $lcars-muted)
    color var(--lcars-text-invert, $lcars-text-invert)
    font-family inherit
    font-size 1rem
    font-weight 700
    text-transform uppercase
    letter-spacing 0.04em
    cursor pointer
    user-select none
    transition filter 0.12s ease, background 0.12s ease
    &:hover
      filter brightness(1.12)
    &:focus-visible
      outline 0.2rem solid var(--lcars-pale-canary, $lcars-pale-canary)
      outline-offset 0.1rem

  &__tab:first-child
    pill-left()
  &__tab:last-child
    pill-right()

  &__tab.is-active
    background var(--lcars-primary, $lcars-primary)

  &__tab:disabled,
  &__tab.is-disabled
    opacity 0.35
    cursor not-allowed
    pointer-events none

  // Vertical orientation
  &--vertical
    flex-direction column
    .lcars-tabs__tab:first-child
      border-radius 0
      border-top-left-radius var(--lcars-radius, $lcars-radius)
      border-top-right-radius var(--lcars-radius, $lcars-radius)
    .lcars-tabs__tab:last-child
      border-radius 0
      border-bottom-left-radius var(--lcars-radius, $lcars-radius)
      border-bottom-right-radius var(--lcars-radius, $lcars-radius)
