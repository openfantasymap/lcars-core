// =============================================================================
//  Component · Transporter
// -----------------------------------------------------------------------------
//  Two parts:
//    1. lcars-transporter-pad — the emitter platform (a grid of glowing pads).
//    2. lcars-transporter      — the chamber, where a subject de/rematerialises
//                                inside a confinement beam.
//
//    <div class="lcars-transporter is-energizing">
//      <div class="lcars-transporter__subject">◊</div>
//      <div class="lcars-transporter__beam"></div>
//    </div>
//
//  Chamber states:
//    --cycle            loops demat ↔ remat forever (great for demos)
//    is-dematerializing one-shot fade-out
//    is-materializing   one-shot fade-in
//    is-energizing      shows the confinement beam, subject steady
//  Tune speed with `--rate`.
// =============================================================================

// ---- Emitter platform --------------------------------------------------------
.lcars-transporter-pad
  display inline-grid
  grid-template-columns repeat(3, 1fr)
  gap 0.6rem
  padding 1rem
  background var(--lcars-panel, $lcars-panel)
  border-radius var(--lcars-radius, $lcars-radius)

  &__pad
    width 3rem
    height 3rem
    border-radius 50%
    background var(--lcars-bg, $lcars-bg)
    box-shadow inset 0 0 0 3px var(--lcars-accent, $lcars-accent)
    transition box-shadow 0.2s ease, background 0.2s ease

  &__pad.is-active
    background radial-gradient(circle, var(--lcars-pale-canary, $lcars-pale-canary) 0%, var(--lcars-accent, $lcars-accent) 70%)
    box-shadow inset 0 0 0 3px var(--lcars-pale-canary, $lcars-pale-canary), 0 0 1rem var(--lcars-accent, $lcars-accent)
    animation lcars-pad-glow 1.2s ease-in-out infinite

  &__pad.is-locked
    box-shadow inset 0 0 0 3px var(--lcars-success, $lcars-success), 0 0 0.6rem var(--lcars-success, $lcars-success)

  // Whole platform energising — staggered ripple across the pads
  &--energizing &__pad
    background radial-gradient(circle, var(--lcars-pale-canary, $lcars-pale-canary) 0%, var(--lcars-accent, $lcars-accent) 70%)
    animation lcars-pad-glow 1s ease-in-out infinite
  &--energizing &__pad:nth-child(2n)
    animation-delay 0.25s
  &--energizing &__pad:nth-child(3n)
    animation-delay 0.5s

// ---- Materialisation chamber -------------------------------------------------
.lcars-transporter
  --rate 2.4s
  position relative
  display grid
  place-items center
  width 14rem
  height 18rem
  padding 1rem
  background var(--lcars-bg, $lcars-bg)
  border-radius var(--lcars-radius, $lcars-radius)
  box-shadow inset 0 0 0 3px var(--lcars-accent, $lcars-accent)
  overflow hidden

  &__subject
    position relative
    z-index 1
    display grid
    place-items center
    font-size 4rem
    line-height 1
    color var(--lcars-pale-canary, $lcars-pale-canary)

  // The confinement beam — rising sparkle rows + vertical containment columns
  &__beam
    position absolute
    inset 0
    z-index 2
    pointer-events none
    opacity 0
    background-image repeating-linear-gradient(0deg, rgba(255, 255, 153, 0) 0, rgba(255, 255, 153, 0.9) 1px, rgba(255, 255, 153, 0) 2px, rgba(255, 255, 153, 0) 9px), repeating-linear-gradient(90deg, rgba(255, 204, 102, 0) 0, rgba(255, 204, 102, 0.45) 1px, rgba(255, 204, 102, 0) 2px, rgba(255, 204, 102, 0) 16px)
    background-size 100% 9px, 16px 100%

  // ---- States ----
  &.is-energizing &__beam,
  &--cycle &__beam
    opacity 1
    animation lcars-beam-shimmer 0.9s linear infinite

  &.is-dematerializing &__subject
    animation lcars-dematerialize var(--rate) ease-in forwards
  &.is-dematerializing &__beam
    opacity 1
    animation lcars-beam-shimmer 0.9s linear infinite

  &.is-materializing &__subject
    animation lcars-materialize var(--rate) ease-out forwards
  &.is-materializing &__beam
    opacity 1
    animation lcars-beam-shimmer 0.9s linear infinite

  &--cycle &__subject
    animation lcars-beam-subject var(--rate) ease-in-out infinite

  // Data-driven materialisation: drive --progress 0 (gone) → 100 (solid).
  // Subject fades/sharpens as it materialises; the beam fades out as it solidifies.
  &--progress &__subject
    opacity calc(var(--progress, 100) / 100)
    filter blur(calc((100 - var(--progress, 100)) * 0.04px)) brightness(calc(1 + (100 - var(--progress, 100)) / 100))
    transition opacity 0.2s linear, filter 0.2s linear
  &--progress &__beam
    opacity calc((100 - var(--progress, 100)) / 100)
    animation lcars-beam-shimmer 0.9s linear infinite

// Console: pad + chamber + controls laid out together
.lcars-transporter-console
  display flex
  flex-wrap wrap
  gap 1.25rem
  align-items flex-start
  box-sizing border-box
  padding 1rem
  background var(--lcars-panel, $lcars-panel)
  border-radius var(--lcars-radius, $lcars-radius)
  &__controls
    display flex
    flex-direction column
    gap 0.5rem
    min-width 11rem

@keyframes lcars-pad-glow
  0%, 100%
    box-shadow inset 0 0 0 3px var(--lcars-accent, $lcars-accent)
    filter brightness(0.8)
  50%
    box-shadow inset 0 0 0 3px var(--lcars-pale-canary, $lcars-pale-canary), 0 0 1.1rem var(--lcars-accent, $lcars-accent)
    filter brightness(1.3)

@keyframes lcars-beam-shimmer
  0%
    background-position 0 0, 0 0
    opacity 0.45
  50%
    opacity 1
  100%
    background-position 0 -9px, 0 0
    opacity 0.45

@keyframes lcars-dematerialize
  0%
    opacity 1
    filter brightness(1)
  20%
    opacity 0.6
  35%
    opacity 0.9
    filter brightness(1.6) saturate(1.4)
  55%
    opacity 0.3
  75%
    opacity 0.55
  100%
    opacity 0
    filter brightness(2.2) blur(2px)

@keyframes lcars-materialize
  0%
    opacity 0
    filter brightness(2.2) blur(2px)
  25%
    opacity 0.45
  45%
    opacity 0.2
  65%
    opacity 0.7
    filter brightness(1.5) saturate(1.3)
  100%
    opacity 1
    filter brightness(1)

@keyframes lcars-beam-subject
  0%, 100%
    opacity 1
    filter brightness(1)
  30%
    opacity 0.25
    filter brightness(2) blur(2px)
  50%
    opacity 0
  70%
    opacity 0.25
    filter brightness(2) blur(2px)
