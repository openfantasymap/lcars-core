// =============================================================================
//  Component · Overview (annotated SVG schematic)
// -----------------------------------------------------------------------------
//  A general-purpose schematic. Bring your own SVG (deck plan, systems diagram,
//  EPS grid…) and annotate elements; the library themes + statuses them via
//  pure CSS, and the JS interpreter (loadOverview) wires interaction + binding.
//
//  Annotation convention (on any SVG element):
//    data-lcars-region              mark as an interactive/status region
//    data-lcars-id="reactor"        logical id (for setStatus / select events)
//    data-lcars-label="M/ARA Core"  name (legend / tooltip / aria)
//    data-lcars-role="primary"      static fill from a theme role
//    data-lcars-status="critical"   status fill: nominal·warning·critical·offline
//    data-bind-attr="data-lcars-status: reactorState"   ← live binding (optional)
//
//    <div class="lcars-overview">
//      <div class="lcars-overview__header">
//        <span class="lcars-overview__title">Systems Overview</span>
//        <span class="lcars-overview__summary">6 systems</span>
//      </div>
//      <div class="lcars-overview__stage"><!-- SVG injected here --></div>
//      <div class="lcars-overview__legend"></div>
//    </div>
// =============================================================================

// Static role fills (theme-aware). Emitted before .lcars-overview so the
// status fills inside that block win at equal specificity. Selector is built
// as a string because interpolation can't reach inside a quoted attr value.
for $role in $lcars-variant-roles
  {'.lcars-overview__stage [data-lcars-role="' + $role + '"]'}
    fill role($role)

.lcars-overview
  display flex
  flex-direction column
  gap 0.6rem
  box-sizing border-box
  min-width 24rem
  padding 1rem
  background var(--lcars-panel, $lcars-panel)
  border-radius var(--lcars-radius, $lcars-radius)
  box-shadow inset 0 0 0 3px var(--lcars-primary, $lcars-primary)

  &__header
    display flex
    justify-content space-between
    align-items baseline
  &__title
    font-weight 700
    text-transform uppercase
    letter-spacing 0.06em
    color var(--lcars-primary, $lcars-primary)
  &__summary
    font-size 0.85rem
    color var(--lcars-muted, $lcars-muted)

  &__stage
    position relative
    width 100%
    svg
      display block
      width 100%
      height auto
    text
      font-family var(--lcars-font, $lcars-font)
      fill var(--lcars-text, $lcars-text)

  // ---- SVG annotations, themed purely in CSS ----
  // Conduits / connective lines
  &__stage .lcars-svg-conduit
    stroke var(--lcars-muted, $lcars-muted)
    stroke-width 3
    fill none
  // On-shape labels
  &__stage .lcars-svg-label
    fill var(--lcars-text-invert, $lcars-text-invert)
    font-weight 700
    text-anchor middle
    pointer-events none

  // Region base
  &__stage [data-lcars-region]
    fill var(--lcars-muted, $lcars-muted)
    stroke var(--lcars-bg, $lcars-bg)
    stroke-width 1.5
    cursor pointer
    outline none
    transition fill 0.25s ease, stroke 0.25s ease, opacity 0.25s ease

  // Static role fills are emitted at top level below (interpolation can't reach
  // inside a quoted attribute value when nested).

  // Status fills (declared after roles → win at equal specificity)
  &__stage [data-lcars-status="nominal"]
    fill var(--lcars-success, $lcars-success)
  &__stage [data-lcars-status="warning"]
    fill var(--lcars-warning, $lcars-warning)
  &__stage [data-lcars-status="critical"]
    fill var(--lcars-danger, $lcars-danger)
    animation lcars-svg-pulse 1s ease-in-out infinite
  &__stage [data-lcars-status="offline"]
    fill var(--lcars-muted, $lcars-muted)
    opacity 0.35

  // Hover / focus / selected
  &__stage [data-lcars-region]:hover,
  &__stage [data-lcars-region]:focus-visible
    stroke var(--lcars-pale-canary, $lcars-pale-canary)
    stroke-width 2.5
  &__stage [data-lcars-region].is-selected
    stroke var(--lcars-pale-canary, $lcars-pale-canary)
    stroke-width 3

  // ---- Legend ----
  &__legend
    display flex
    flex-wrap wrap
    gap 0.75rem
  &__legend-item
    display inline-flex
    align-items center
    gap 0.4rem
    font-size 0.8rem
    text-transform uppercase
    letter-spacing 0.03em
    color var(--lcars-text, $lcars-text)
    background none
    border none
    cursor pointer
  &__swatch
    width 0.9rem
    height 0.9rem
    border-radius 0.2rem
    background var(--lcars-muted, $lcars-muted)
    &[data-lcars-status="nominal"]
      background var(--lcars-success, $lcars-success)
    &[data-lcars-status="warning"]
      background var(--lcars-warning, $lcars-warning)
    &[data-lcars-status="critical"]
      background var(--lcars-danger, $lcars-danger)
    &[data-lcars-status="offline"]
      background var(--lcars-muted, $lcars-muted)

@keyframes lcars-svg-pulse
  0%, 100%
    opacity 1
  50%
    opacity 0.4
