// =============================================================================
//  LCARS · Sizing grid
// -----------------------------------------------------------------------------
//  The LCARS metric grid. Width units (`lcars-u-N`) step by one column, height
//  units (`lcars-vu-N`) step by one row. Generated with loops rather than the
//  256 hand-written rules the old app shipped.
//
//    width(n)  = 7.5rem  + (n-1) * 7.75rem   (column + gap)
//    height(n) = 3rem    + (n-1) * 3.25rem   (row + gap)
// =============================================================================

$lcars-grid-steps = 16

for $n in 1..$lcars-grid-steps
  .lcars-u-{$n}
    width (7.5rem + ($n - 1) * 7.75rem)
    min-width (7.5rem + ($n - 1) * 7.75rem)

  .lcars-vu-{$n}
    height (3rem + ($n - 1) * 3.25rem)
    min-height (3rem + ($n - 1) * 3.25rem)

// Half a base column (handy for tight button pairs)
.lcars-u-half
  width 3.625rem
  min-width 3.625rem

// Spacers
.lcars-spacer
  flex 0 0 var(--lcars-gap, $lcars-gap)
.lcars-spacer-2
  flex 0 0 (2 * $lcars-gap)
.lcars-spacer-4
  flex 0 0 (4 * $lcars-gap)
.lcars-grow
  flex 1 1 auto
