// =============================================================================
//  Component · Toggle switch
// -----------------------------------------------------------------------------
//  A pure-CSS on/off switch driven by a hidden checkbox.
//
//    <label class="lcars-toggle">
//      <input type="checkbox" class="lcars-toggle__input" checked>
//      <span class="lcars-toggle__track"><span class="lcars-toggle__knob"></span></span>
//      <span class="lcars-toggle__label">Deflector Dish</span>
//    </label>
// =============================================================================

.lcars-toggle
  display inline-flex
  align-items center
  gap 0.6rem
  cursor pointer
  user-select none

  &__input
    visually-hidden()

  &__track
    position relative
    flex 0 0 auto
    width 4rem
    height 1.75rem
    border-radius 0.875rem
    background var(--lcars-panel, $lcars-panel)
    box-shadow inset 0 0 0 2px var(--lcars-muted, $lcars-muted)
    transition box-shadow 0.15s ease, background 0.15s ease

  &__knob
    position absolute
    top 0.15rem
    left 0.15rem
    width 1.45rem
    height 1.45rem
    border-radius 50%
    background var(--lcars-muted, $lcars-muted)
    transition left 0.15s ease, background 0.15s ease

  &__label
    font-weight 700
    text-transform uppercase
    letter-spacing 0.04em
    color var(--lcars-text, $lcars-text)

  // ---- ON ----
  &__input:checked ~ &__track
    background var(--lcars-bg, $lcars-bg)
    box-shadow inset 0 0 0 2px var(--lcars-success, $lcars-success)
  &__input:checked ~ &__track &__knob
    left 2.4rem
    background var(--lcars-success, $lcars-success)

  // ---- focus ring ----
  &__input:focus-visible ~ &__track
    outline 0.2rem solid var(--lcars-pale-canary, $lcars-pale-canary)
    outline-offset 0.15rem

  // ---- disabled ----
  &.is-disabled
    opacity 0.4
    cursor not-allowed

  // Colour variant of the "on" state
  for $role in $lcars-variant-roles
    &.lcars-toggle--{$role} &__input:checked ~ &__track
      box-shadow inset 0 0 0 2px role($role)
    &.lcars-toggle--{$role} &__input:checked ~ &__track &__knob
      background role($role)
