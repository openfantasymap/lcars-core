// =============================================================================
//  Component · Nav (sidebar menu)
// -----------------------------------------------------------------------------
//  The stacked-button sidebar. Items round outward at the top and bottom of the
//  stack so the column reads as one continuous rail. Pair with elbows for the
//  full frame.
//
//    <nav class="lcars-nav">
//      <a class="lcars-nav__item is-active">Bridge</a>
//      <a class="lcars-nav__item">Engineering</a>
//      <a class="lcars-nav__item">Sickbay</a>
//      <span class="lcars-nav__spacer"></span>
//      <a class="lcars-nav__item lcars-nav__item--danger">Eject Core</a>
//    </nav>
//
//  Multi-colour by default; add `--mono` to keep the whole rail one colour.
// =============================================================================

.lcars-nav
  display flex
  flex-direction column
  gap var(--lcars-gap, $lcars-gap)
  width 9.5rem
  min-width 9.5rem

  &__item
    display flex
    align-items flex-end
    justify-content flex-end
    box-sizing border-box
    min-height 2.6rem
    padding 0.3rem 0.6rem
    background var(--lcars-secondary, $lcars-secondary)
    color var(--lcars-text-invert, $lcars-text-invert)
    font-weight 700
    font-size 0.95rem
    text-align right
    text-transform uppercase
    letter-spacing 0.03em
    text-decoration none
    cursor pointer
    user-select none
    transition filter 0.12s ease, background 0.12s ease
    &:hover
      filter brightness(1.12)
    &:focus-visible
      outline 0.2rem solid var(--lcars-pale-canary, $lcars-pale-canary)
      outline-offset -0.2rem

  // Default multi-colour cycle (low specificity so overrides win)
  &__item:nth-child(odd)
    background var(--lcars-secondary, $lcars-secondary)
  &__item:nth-child(even)
    background var(--lcars-lilac, $lcars-lilac)

  // Round the rail's ends
  &__item:first-child
    border-top-left-radius var(--lcars-radius, $lcars-radius)
    border-top-right-radius var(--lcars-radius, $lcars-radius)
  &__item:last-child
    border-bottom-left-radius var(--lcars-radius, $lcars-radius)
    border-bottom-right-radius var(--lcars-radius, $lcars-radius)

  // Mono opt-out (two classes → beats the cycle)
  &--mono &__item
    background var(--lcars-secondary, $lcars-secondary)

  // Per-item colour override (two classes → beats the nth-child cycle)
  for $role in $lcars-variant-roles
    &__item.lcars-nav__item--{$role}
      background role($role)

  // Active item (declared last so it wins at equal specificity)
  &__item.is-active
    background var(--lcars-primary, $lcars-primary)
    color var(--lcars-text-invert, $lcars-text-invert)

  // Push subsequent items to the bottom of the rail
  &__spacer
    flex 1 1 auto
    min-height 1rem

  // Small section heading
  &__group
    padding 0.2rem 0.6rem
    font-size 0.75rem
    text-transform uppercase
    letter-spacing 0.1em
    color var(--lcars-muted, $lcars-muted)
    text-align right

  // Horizontal orientation (top rail)
  &--horizontal
    flex-direction row
    width auto
    min-width 0
    .lcars-nav__item:first-child
      border-radius 0
      border-top-left-radius var(--lcars-radius, $lcars-radius)
      border-bottom-left-radius var(--lcars-radius, $lcars-radius)
    .lcars-nav__item:last-child
      border-radius 0
      border-top-right-radius var(--lcars-radius, $lcars-radius)
      border-bottom-right-radius var(--lcars-radius, $lcars-radius)
