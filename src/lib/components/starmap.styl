// =============================================================================
//  Component · Stellar map (CONN)
// -----------------------------------------------------------------------------
//  A sector grid (stellar cartography) with star markers, an ownship marker, a
//  destination waypoint, and a course vector. Everything is placed in percent
//  coordinates (--x / --y, 0–100, origin top-left).
//
//    <div class="lcars-starmap">
//      <span class="lcars-starmap__star" style="--x:20;--y:35;"></span>
//      <span class="lcars-starmap__star lcars-starmap__star--giant" style="--x:70;--y:60;"></span>
//      <div class="lcars-starmap__course" style="--x:30;--y:50;--len:9rem;--angle:-18;"></div>
//      <span class="lcars-starmap__ship" style="--x:30;--y:50;"></span>
//      <span class="lcars-starmap__waypoint" style="--x:78;--y:30;"></span>
//      <span class="lcars-starmap__label">SECTOR 001</span>
//    </div>
// =============================================================================

.lcars-starmap
  position relative
  width 22rem
  height 14rem
  box-sizing border-box
  border-radius var(--lcars-radius, $lcars-radius)
  background-color var(--lcars-bg, $lcars-bg)
  background-image linear-gradient(rgba(153, 153, 204, 0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(153, 153, 204, 0.12) 1px, transparent 1px)
  background-size 2.2rem 2.2rem
  box-shadow inset 0 0 0 3px var(--lcars-primary, $lcars-primary)
  overflow hidden

  &__star
    position absolute
    left calc(var(--x) * 1%)
    top calc(var(--y) * 1%)
    width 0.4rem
    height 0.4rem
    border-radius 50%
    background var(--lcars-space-white, #f5f6fa)
    box-shadow 0 0 0.4rem rgba(255, 255, 255, 0.7)
    transform translate(-50%, -50%)
    &--giant
      width 0.7rem
      height 0.7rem
      background var(--lcars-butterscotch, $lcars-butterscotch)
      box-shadow 0 0 0.6rem var(--lcars-butterscotch, $lcars-butterscotch)
    &--dim
      opacity 0.5

  // Course vector: a line anchored at the ship, length + angle as vars
  &__course
    position absolute
    left calc(var(--x) * 1%)
    top calc(var(--y) * 1%)
    height 2px
    width var(--len, 8rem)
    background repeating-linear-gradient(90deg, var(--lcars-pale-canary, $lcars-pale-canary) 0 0.4rem, transparent 0.4rem 0.7rem)
    transform-origin left center
    transform rotate(calc(var(--angle, 0) * 1deg))
    z-index 1

  &__ship
    position absolute
    left calc(var(--x) * 1%)
    top calc(var(--y) * 1%)
    width 0
    height 0
    border-left 0.55rem solid transparent
    border-right 0.55rem solid transparent
    border-bottom 0.95rem solid var(--lcars-primary, $lcars-primary)
    transform translate(-50%, -50%) rotate(calc(var(--rot, 0) * 1deg))
    filter drop-shadow(0 0 0.4rem var(--lcars-primary, $lcars-primary))
    z-index 2

  &__waypoint
    position absolute
    left calc(var(--x) * 1%)
    top calc(var(--y) * 1%)
    width 1rem
    height 1rem
    border-radius 50%
    border 2px solid var(--lcars-pale-canary, $lcars-pale-canary)
    transform translate(-50%, -50%)
    z-index 2
    animation lcars-pulse 1.6s ease-in-out infinite
    &::after
      content ''
      position absolute
      left 50%
      top 50%
      width 0.3rem
      height 0.3rem
      border-radius 50%
      background var(--lcars-pale-canary, $lcars-pale-canary)
      transform translate(-50%, -50%)

  &__label
    position absolute
    left 0.5rem
    bottom 0.4rem
    font-size 0.8rem
    font-weight 700
    text-transform uppercase
    letter-spacing 0.08em
    color var(--lcars-muted, $lcars-muted)
