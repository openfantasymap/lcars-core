// =============================================================================
//  Component · Bar graph / Equalizer
// -----------------------------------------------------------------------------
//  Vertical bars, each driven by a per-bar `--value` (0–100). Optionally set
//  `--lcars-bargraph-h` for height. The `--live` modifier animates a scan.
//
//    <div class="lcars-bargraph">
//      <div class="lcars-bargraph__bar" style="--value:80"></div>
//      <div class="lcars-bargraph__bar" style="--value:35"></div>
//      …
//    </div>
// =============================================================================

.lcars-bargraph
  display flex
  align-items flex-end
  gap var(--lcars-gap, $lcars-gap)
  height var(--lcars-bargraph-h, 9rem)
  padding 0.5rem
  background var(--lcars-panel, $lcars-panel)
  border-radius var(--lcars-gap, $lcars-gap)

  &__bar
    --value 50
    flex 1 1 auto
    min-width 1.25rem
    height calc(var(--value) * 1%)
    background var(--lcars-primary, $lcars-primary)
    border-radius 0.25rem 0.25rem 0 0
    transition height 0.3s ease
    align-self flex-end

  // Palette cycling for the classic multicolour spectrum
  &:not(.lcars-bargraph--mono) &__bar:nth-child(5n+1)
    background var(--lcars-primary, $lcars-primary)
  &:not(.lcars-bargraph--mono) &__bar:nth-child(5n+2)
    background var(--lcars-secondary, $lcars-secondary)
  &:not(.lcars-bargraph--mono) &__bar:nth-child(5n+3)
    background var(--lcars-tertiary, $lcars-tertiary)
  &:not(.lcars-bargraph--mono) &__bar:nth-child(5n+4)
    background var(--lcars-butterscotch, $lcars-butterscotch)
  &:not(.lcars-bargraph--mono) &__bar:nth-child(5n+5)
    background var(--lcars-hopbush, $lcars-hopbush)

  // Animated "scanning" equalizer
  &--live &__bar
    animation lcars-eq 1.1s ease-in-out infinite alternate
    transform-origin bottom
  &--live &__bar:nth-child(2n)
    animation-delay 0.2s
  &--live &__bar:nth-child(3n)
    animation-delay 0.45s
  &--live &__bar:nth-child(4n)
    animation-delay 0.7s

@keyframes lcars-eq
  from
    transform scaleY(0.45)
  to
    transform scaleY(1)
