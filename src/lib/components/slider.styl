// =============================================================================
//  Component · Slider (horizontal + vertical)
// -----------------------------------------------------------------------------
//  A presentational LCARS slider driven by a `--value` (0–100) custom property,
//  so it animates from a single number — perfect for Storybook controls and for
//  binding to live telemetry.
//
//    <div class="lcars-slider lcars-slider--primary" style="--value:72">
//      <div class="lcars-slider__track">
//        <div class="lcars-slider__fill"></div>
//        <div class="lcars-slider__knob"></div>
//      </div>
//    </div>
// =============================================================================

.lcars-slider
  --value 50
  display block
  width 100%

  &__track
    position relative
    width 100%
    height var(--lcars-bar-thickness, $lcars-bar-thickness)
    border-radius var(--lcars-radius, $lcars-radius)
    background var(--lcars-panel, $lcars-panel)
    box-shadow inset 0 0 0 2px var(--lcars-muted, $lcars-muted)
    overflow hidden

  &__fill
    position absolute
    top 0
    left 0
    height 100%
    width calc(var(--value) * 1%)
    background var(--lcars-primary, $lcars-primary)
    transition width 0.2s ease

  &__knob
    position absolute
    top -0.35rem
    left calc(var(--value) * 1%)
    transform translateX(-50%)
    width 0.9rem
    height calc(var(--lcars-bar-thickness, 1.5rem) + 0.7rem)
    border-radius 0.45rem
    background var(--lcars-pale-canary, $lcars-pale-canary)
    box-shadow 0 0 0.4rem rgba(0, 0, 0, 0.6)
    transition left 0.2s ease

  // Optional inline value plaque
  &__value
    display inline-block
    margin-top 0.35rem
    font-variant-numeric tabular-nums
    font-weight 700
    color var(--lcars-primary, $lcars-primary)

  // ---- Vertical ----
  &--vertical
    display inline-block
    width var(--lcars-bar-thickness, $lcars-bar-thickness)
    height 12rem
    .lcars-slider__track
      width 100%
      height 100%
    .lcars-slider__fill
      top auto
      bottom 0
      left 0
      width 100%
      height calc(var(--value) * 1%)
      transition height 0.2s ease
    .lcars-slider__knob
      top auto
      left 50%
      bottom calc(var(--value) * 1%)
      transform translate(-50%, 50%)
      width calc(var(--lcars-bar-thickness, 1.5rem) + 0.7rem)
      height 0.9rem

  // Colour variants recolour the fill
  for $role in $lcars-variant-roles
    &.lcars-slider--{$role} .lcars-slider__fill
      background role($role)
    &.lcars-slider--{$role} .lcars-slider__value
      color role($role)
