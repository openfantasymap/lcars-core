// =============================================================================
//  LCARS · Layout primitives
// -----------------------------------------------------------------------------
//  Flex row/column helpers plus the canonical app shell (sidebar + header +
//  scrolling content). These mirror the class names used in the existing
//  lcars-mqtt app (.lcars-row / .lcars-column) for drop-in parity.
//
//  Classes are top-level (not nested under `.lcars`) so they work anywhere;
//  they pull colours from the nearest `.lcars` ancestor via CSS variables.
// =============================================================================

// --- Row ----------------------------------------------------------------------
.lcars-row
  display flex
  flex-direction row
  width 100%
  gap var(--lcars-gap, $lcars-gap)
  &.fill
    flex 1
  &.centered
    justify-content center
  &.full-centered
    justify-content center
    align-items center
  &.right
    justify-content flex-end
  &.right-centered
    justify-content flex-end
    align-items center
  &.space-between
    justify-content space-between
  &.bottom
    align-items flex-end
  &.wrap
    flex-wrap wrap

// --- Column -------------------------------------------------------------------
.lcars-column
  display flex
  flex-direction column
  gap var(--lcars-gap, $lcars-gap)
  &.fill
    flex 1
  &.centered
    justify-content center
  &.full-centered
    justify-content center
    align-items center
  &.centered-right
    align-items flex-end
  &.bottom
    justify-content flex-end

// --- Panel: a plain dark content surface --------------------------------------
.lcars-panel
  background var(--lcars-panel, $lcars-panel)
  color var(--lcars-text, $lcars-text)
  padding 1rem
  border-radius var(--lcars-gap, $lcars-gap)

// --- App shell ----------------------------------------------------------------
//  <div class="lcars lcars-app">
//    <aside class="lcars-app__sidebar">…nav…</aside>
//    <header class="lcars-app__header">…bars…</header>
//    <main class="lcars-app__content">…</main>
//  </div>
.lcars-app
  display grid
  grid-template-columns auto 1fr
  grid-template-rows auto 1fr
  grid-template-areas "sidebar header" "sidebar content"
  gap var(--lcars-gap, $lcars-gap)
  width 100%
  height 100%
  min-height 100vh
  padding var(--lcars-gap, $lcars-gap)
  background var(--lcars-bg, $lcars-bg)

.lcars-app__sidebar
  grid-area sidebar
  display flex
  flex-direction column
  gap var(--lcars-gap, $lcars-gap)
  min-width 9.5rem

.lcars-app__header
  grid-area header
  display flex
  gap var(--lcars-gap, $lcars-gap)

.lcars-app__content
  grid-area content
  overflow auto
  padding-top var(--lcars-gap, $lcars-gap)
