// =============================================================================
//  Component · Button (a.k.a. "element")
// -----------------------------------------------------------------------------
//  The pill control. Bottom/right-aligned label by convention.
//
//    <button class="lcars-button lcars-button--primary">Engage</button>
//    <button class="lcars-button lcars-button--rounded lcars-button--danger">
//      Red Alert
//    </button>
//
//  Shapes:  (default rounds the right end) · --rounded · --left · --square
//  States:  --inactive (outlined) · [disabled]
// =============================================================================

.lcars-button
  display inline-flex
  flex-direction row
  align-items flex-end
  justify-content flex-end
  box-sizing border-box
  min-width var(--lcars-unit-w, $lcars-unit-w)
  height var(--lcars-unit-h, $lcars-unit-h)
  padding 0.3rem 0.75rem
  border none
  border-radius 0
  pill-right()
  background var(--lcars-primary, $lcars-primary)
  color var(--lcars-text-invert, $lcars-text-invert)
  font-family inherit
  font-size 1.05rem
  font-weight 700
  line-height 1.05
  text-align right
  text-transform uppercase
  letter-spacing 0.04em
  text-decoration none
  cursor pointer
  user-select none
  appearance none
  transition background-color 0.12s ease, filter 0.12s ease, transform 0.05s ease

  &:hover
    filter brightness(1.12)
  &:active
    background var(--lcars-hopbush, $lcars-hopbush)
    transform translateY(1px)
  &:focus-visible
    outline 0.2rem solid var(--lcars-pale-canary, $lcars-pale-canary)
    outline-offset 0.15rem

  // Shapes
  &--rounded
    pill()
  &--left
    pill-left()
    border-top-right-radius 0
    border-bottom-right-radius 0
    text-align left
    justify-content flex-start
  &--square
    border-radius 0

  // Colour variants (background)
  lcars-color-variants()

  // Outlined / inactive
  &--inactive,
  &.is-inactive
    background var(--lcars-bg, $lcars-bg)
    color var(--lcars-primary, $lcars-primary)
    box-shadow inset 0 0 0 2px var(--lcars-primary, $lcars-primary)
    &:hover
      filter none
      background rgba(255, 255, 255, 0.05)

  // Disabled
  &:disabled,
  &.is-disabled
    cursor not-allowed
    opacity 0.35
    filter grayscale(0.4)
    pointer-events none

  // Optional black numeric badge tucked on the inner edge
  &__badge
    align-self stretch
    display flex
    align-items flex-end
    margin 0 0.4rem 0 -0.35rem
    padding 0 0.35rem
    background var(--lcars-bg, $lcars-bg)
    color var(--lcars-text, $lcars-text)
    font-size 1.4rem
    font-variant-numeric tabular-nums
