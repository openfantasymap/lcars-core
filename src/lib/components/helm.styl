// =============================================================================
//  Component · Helm console (CONN)
// -----------------------------------------------------------------------------
//  The speed/throttle station: warp factor + impulse readouts, segmented bars,
//  a throttle, and distance/ETA plaques.
//
//    <div class="lcars-helm" style="--warp:6.2;--impulse:75;--throttle:80;">
//      <div class="lcars-helm__head">
//        <div class="lcars-helm__metric"><span class="lcars-helm__label">Warp</span>
//          <span class="lcars-helm__value">6.2</span></div>
//        <div class="lcars-helm__metric"><span class="lcars-helm__label">Impulse</span>
//          <span class="lcars-helm__value">75%</span></div>
//      </div>
//      <div class="lcars-helm__bar lcars-helm__bar--warp" style="--segments:9;">
//        <div class="lcars-helm__fill"></div></div>
//      <div class="lcars-helm__bar lcars-helm__bar--impulse"><div class="lcars-helm__fill"></div></div>
//      <span class="lcars-helm__throttle-label">Throttle</span>
//      <div class="lcars-helm__bar lcars-helm__bar--throttle"><div class="lcars-helm__fill"></div></div>
//      <div class="lcars-helm__readouts">…lcars-readout plaques…</div>
//    </div>
// =============================================================================

.lcars-helm
  --warp 5
  --impulse 50
  --throttle 50
  display inline-flex
  flex-direction column
  gap 0.6rem
  box-sizing border-box
  min-width 22rem
  padding 1rem
  background var(--lcars-panel, $lcars-panel)
  border-radius var(--lcars-radius, $lcars-radius)

  &__head
    display flex
    justify-content space-between
    gap 1rem

  &__metric
    display flex
    flex-direction column

  &__label
    font-size 0.75rem
    text-transform uppercase
    letter-spacing 0.08em
    color var(--lcars-muted, $lcars-muted)

  &__value
    font-size 2.2rem
    font-weight 700
    line-height 1
    color var(--lcars-primary, $lcars-primary)
    font-variant-numeric tabular-nums

  // Segmented progress bar
  &__bar
    --segments 10
    position relative
    height 1.4rem
    border-radius 0.3rem
    background var(--lcars-bg, $lcars-bg)
    box-shadow inset 0 0 0 2px var(--lcars-muted, $lcars-muted)
    overflow hidden
    // segment dividers
    &::after
      content ''
      position absolute
      inset 0
      background repeating-linear-gradient(90deg, transparent 0 calc(100% / var(--segments) - 2px), var(--lcars-bg, $lcars-bg) calc(100% / var(--segments) - 2px) calc(100% / var(--segments)))
      pointer-events none
      z-index 1

  &__fill
    position absolute
    left 0
    top 0
    height 100%
    background var(--lcars-primary, $lcars-primary)
    transition width 0.3s ease

  &__bar--warp .lcars-helm__fill
    width calc(var(--warp) / 9 * 100%)
    background var(--lcars-primary, $lcars-primary)
  &__bar--impulse .lcars-helm__fill
    width calc(var(--impulse) * 1%)
    background var(--lcars-secondary, $lcars-secondary)
  &__bar--throttle
    height 1.9rem
  &__bar--throttle .lcars-helm__fill
    width calc(var(--throttle) * 1%)
    background var(--lcars-butterscotch, $lcars-butterscotch)

  &__throttle-label
    margin-top 0.1rem
    font-size 0.75rem
    text-transform uppercase
    letter-spacing 0.08em
    color var(--lcars-muted, $lcars-muted)

  &__readouts
    display flex
    flex-wrap wrap
    gap 0.4rem
    margin-top 0.2rem
